    {
      "name": "UI Regression (Playwright Findings)",
      "item": [
        {
          "name": "Employees list (UI BUG-001 validation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ========================================\r",
                  "// UI Regression - BUG-001 validation\r",
                  "// Employees (list) should NOT be empty when an employee exists\r",
                  "// ========================================\r",
                  "\r",
                  "// 1) Basic response checks\r",
                  "pm.test(\"Status is 200\", () => {\r",
                  "  pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is JSON\", () => {\r",
                  "  pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "// 2) Response structure validation\r",
                  "pm.test(\"Response is an array\", () => {\r",
                  "  pm.expect(jsonData, \"Expected an array from GET /api/Employees\").to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "// 3) Validate employee visibility\r",
                  "const savedId = pm.collectionVariables.get(\"employeeId\");\r",
                  "\r",
                  "if (savedId) {\r",
                  "\r",
                  "  const employee = jsonData.find(e => e.id === savedId);\r",
                  "\r",
                  "  pm.test(\"Created employee is visible in the list (supports UI BUG-001)\", () => {\r",
                  "    pm.expect(employee, `Employee ${savedId} was not found`).to.exist;\r",
                  "  });\r",
                  "\r",
                  "  // 4) Validate employee fields\r",
                  "  if (employee) {\r",
                  "\r",
                  "    pm.test(\"Employee list item has expected fields\", () => {\r",
                  "      pm.expect(employee).to.have.property(\"id\");\r",
                  "      pm.expect(employee).to.have.property(\"firstName\");\r",
                  "      pm.expect(employee).to.have.property(\"lastName\");\r",
                  "      pm.expect(employee).to.have.property(\"dependants\");\r",
                  "    });\r",
                  "\r",
                  "    // 5) Financial fields validation\r",
                  "    pm.test(\"Employee list item includes financial fields\", () => {\r",
                  "      pm.expect(employee).to.have.property(\"gross\");\r",
                  "      pm.expect(employee).to.have.property(\"benefitsCost\");\r",
                  "      pm.expect(employee).to.have.property(\"net\");\r",
                  "    });\r",
                  "\r",
                  "  }\r",
                  "\r",
                  "} else {\r",
                  "\r",
                  "  pm.test(\"employeeId not set (skipping visibility check)\", () => {\r",
                  "    pm.expect(true).to.be.true;\r",
                  "  });\r",
                  "\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Employees",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Employees"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Employee persistence (UI BUG-002 validation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ========================================\r",
                  "// UI Regression - BUG-002 validation\r",
                  "// After submission the employee must exist\r",
                  "// ========================================\r",
                  "\r",
                  "// 1) Basic response checks\r",
                  "pm.test(\"Status is 200\", () => {\r",
                  "  pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is JSON\", () => {\r",
                  "  pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "const savedId = pm.collectionVariables.get(\"employeeId\");\r",
                  "\r",
                  "// 2) This endpoint should return a SINGLE employee\r",
                  "pm.test(\"Response is an object\", () => {\r",
                  "  pm.expect(jsonData).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "// 3) ID validation\r",
                  "pm.test(\"Employee ID matches stored employeeId\", () => {\r",
                  "  pm.expect(savedId).to.exist;\r",
                  "  pm.expect(jsonData.id).to.eql(savedId);\r",
                  "});\r",
                  "\r",
                  "// 4) Employee fields exist\r",
                  "pm.test(\"Employee fields exist\", () => {\r",
                  "  pm.expect(jsonData).to.have.property(\"firstName\");\r",
                  "  pm.expect(jsonData).to.have.property(\"lastName\");\r",
                  "  pm.expect(jsonData).to.have.property(\"dependants\");\r",
                  "  pm.expect(jsonData).to.have.property(\"username\");\r",
                  "});\r",
                  "\r",
                  "// 5) Financial fields exist\r",
                  "pm.test(\"Financial fields exist\", () => {\r",
                  "  pm.expect(jsonData).to.have.property(\"gross\");\r",
                  "  pm.expect(jsonData).to.have.property(\"benefitsCost\");\r",
                  "  pm.expect(jsonData).to.have.property(\"net\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
