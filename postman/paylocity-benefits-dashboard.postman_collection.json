    {
      "name": "Create employee (dependants=0)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ========================================\r",
              "// Create employee (dependants=0)\r",
              "// Creates a new employee and stores employeeId for later requests\r",
              "// ========================================\r",
              "\r",
              "// 1) Basic response checks\r",
              "pm.test(\"Status is 200\", () => {\r",
              "  pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is JSON\", () => {\r",
              "  pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// 2) Response should be a SINGLE employee (object)\r",
              "pm.test(\"Response is an object\", () => {\r",
              "  pm.expect(jsonData, \"Expected an object from POST /api/Employees\").to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "// 3) Required fields exist\r",
              "pm.test(\"Employee object contains required fields\", () => {\r",
              "  [\"id\", \"firstName\", \"lastName\", \"dependants\", \"username\"].forEach((k) => {\r",
              "    pm.expect(jsonData, `Missing field: ${k}`).to.have.property(k);\r",
              "  });\r",
              "});\r",
              "\r",
              "// 4) Save employeeId for the rest of the run\r",
              "pm.test(\"Save employeeId for later requests\", () => {\r",
              "  pm.expect(jsonData.id, \"Response missing field: id\").to.exist;\r",
              "  pm.collectionVariables.set(\"employeeId\", jsonData.id);\r",
              "  pm.expect(pm.collectionVariables.get(\"employeeId\")).to.eql(jsonData.id);\r",
              "});\r",
              "\r",
              "// 5) Ownership validation (dynamic, no hardcode)\r",
              "pm.test(\"Employee belongs to the authenticated user\", () => {\r",
              "  const expectedUser = pm.collectionVariables.get(\"username\");\r",
              "  pm.expect(expectedUser, \"Missing collection variable: username\").to.exist;\r",
              "  pm.expect(jsonData.username).to.eql(expectedUser);\r",
              "});\r",
              "\r",
              "// 6) Financial fields exist + are numbers (safe checks)\r",
              "pm.test(\"Financial fields exist\", () => {\r",
              "  pm.expect(jsonData).to.have.property(\"gross\");\r",
              "  pm.expect(jsonData).to.have.property(\"benefitsCost\");\r",
              "  pm.expect(jsonData).to.have.property(\"net\");\r",
              "});\r",
              "\r",
              "pm.test(\"Financial values are numbers\", () => {\r",
              "  pm.expect(jsonData.gross).to.be.a(\"number\");\r",
              "  pm.expect(jsonData.benefitsCost).to.be.a(\"number\");\r",
              "  pm.expect(jsonData.net).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// 7) Integrity validations\r",
              "pm.test(\"Net is always less than Gross\", () => {\r",
              "  pm.expect(jsonData.net).to.be.below(jsonData.gross);\r",
              "});\r",
              "\r",
              "pm.test(\"Benefits cost is never negative\", () => {\r",
              "  pm.expect(jsonData.benefitsCost).to.be.at.least(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
